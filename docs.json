{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Veviad Documentation",
  "colors": {
    "primary": "#575BDE",
    "light": "#3F63FF",
    "dark": "#211B4E"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "tabs": [
          {
            "tab": "Getting Started",
            "icon": "compass",
            "href": "/getting-started"
          },
          {
            "tab": "User Manual",
            "icon": "book-open",
            "href": "/main"
          },
          {
            "tab": "Internal",
            "icon": "lock",
            "href": "/release-management/release-handbook"
          }
        ]
      },
      {
        "language": "de",
        "tabs": [
          {
            "tab": "Erste Schritte",
            "icon": "compass",
            "href": "/de/getting-started"
          },
          {
            "tab": "Benutzerhandbuch",
            "icon": "book-open",
            "href": "/de/main"
          },
          {
            "tab": "Intern",
            "icon": "lock",
            "href": "/de/operations"
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/veviad-logo-light.svg",
    "dark": "/images/veviad-logo-dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Veviad",
        "href": "https://veviad.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Veviad",
      "href": "https://app.veviad.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "description": "Public user manual and private internal operations documentation for Veviad.",
  "redirects": [
    {
      "source": "/quickstart",
      "destination": "/getting-started",
      "permanent": true
    }
  ],
  "background": {
    "color": {
      "light": "#F7F8FD",
      "dark": "#0D0B38"
    }
  },
  "appearance": {
    "default": "light"
  }
}
