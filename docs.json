          "icon": "newspaper"
        }
      ]
    },
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Release Management",
        "icon": "rocket",
        "pages": [
          "release-management/release-handbook",
          "release-management/hotfix-flow",
